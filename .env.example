# Copy this file to .env.local and fill in values from the Firebase Console.
# Project settings → Your apps → Web app → Firebase SDK snippet

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Spotify Web API (server-side only — do NOT prefix with NEXT_PUBLIC_)
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional: LAN origin for share links when developing on localhost (mobile WiFi testing).
# Ignored in production — deployed app always uses the current domain.
# NEXT_PUBLIC_SHARE_ORIGIN=http://192.168.29.228:3000
